# Caddy runs in another docker-compose (e.g. capy-front).
# PocketBase runs in this repo's docker-compose (capy-leaderboard).
# PocketBase serves everything: frontend (pb_public), API (/api), admin (/_/).
#
# Upstream — pick ONE:
#   Option A (shared network): reverse_proxy capy-leaderboard:8090
#     Caddy compose joins capy-network (external: true), keeps ports 80/443.
#   Option B (host bridge):      reverse_proxy host.docker.internal:8090
#     + extra_hosts: ["host.docker.internal:host-gateway"] on Caddy
#     + ports: "127.0.0.1:8090:8090" on PocketBase compose

gaming.capysecurity.com {
	tls /etc/letsencrypt/live/gaming.capysecurity.com/fullchain.pem /etc/letsencrypt/live/gaming.capysecurity.com/privkey.pem

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}

	reverse_proxy capy-leaderboard:8090
}

# certbot certonly --standalone --non-interactive --agree-tos -m "capy.security@proton.me" -d "gaming.capysecurity.com"
